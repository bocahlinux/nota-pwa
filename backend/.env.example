# Nota Backend — Environment Variables
# Copy this to .env and fill in the values

# ── Core ──
DJANGO_SECRET_KEY=your-super-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──
# For SQLite (development): leave DB_ENGINE unset or set to empty
# For PostgreSQL (production): set DB_ENGINE=postgres
DB_ENGINE=postgres
DB_NAME=nota_db
DB_USER=nota_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ── Push Notifications (Web Push) ──
# Generate VAPID keys: python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print('PUBLIC:', v.public_pem().decode()); print('PRIVATE:', v.private_pem().decode())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=mailto:admin@yourdomain.com
