# Nota Backend — Environment Variables
# Copy this to .env and fill in the values

# ── Core ──
DJANGO_SECRET_KEY=your-super-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──
# For SQLite (development): leave DB_ENGINE unset or set to empty
# For PostgreSQL (production): set DB_ENGINE=postgres
DB_ENGINE=postgres
DB_NAME=nota_db
DB_USER=nota_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ── Media ──
# Max upload size in bytes (default: 10MB)
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
