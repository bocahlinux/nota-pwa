# Nota Frontend — Environment Variables
# Copy this to .env.local for local overrides (do not commit .env.local)

# Backend API URL (used by api.ts for direct API calls)
# Development: http://localhost:8000
# Production:  https://yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# VAPID Public Key for push notifications (must match backend VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
